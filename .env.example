# Copy this file to .env and fill in values for your environment

# Appium server (default: local)
APPIUM_SERVER_URL=http://127.0.0.1:4723

# Android device
DEVICE_NAME=Android Emulator
DEVICE_UDID=emulator-5554

# APK path (leave blank if app is already installed on device)
APP_PATH=

# Set to true to keep app state between test runs
NO_RESET=false
